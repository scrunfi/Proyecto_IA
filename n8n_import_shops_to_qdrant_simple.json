    {
      "parameters": {
        "jsCode": "const out = [];\nfor (const item of $input.all()) {\n  const s = item.json || {};\n  const id = s._id?.toString?.() ?? s.id ?? `shop-${Date.now()}-${Math.random().toString(36).slice(2,8)}`;\n  const barrio = s.barrio?.name ?? s.neighborhood ?? '';\n  const category = s.subcategory ?? s.category ?? '';\n  const address = s.address ?? '';\n  const score = typeof s.score === 'number' ? s.score : '';\n  const gap = typeof s.gap === 'number' ? s.gap : '';\n  const reviews = typeof s.reviews === 'number' ? s.reviews : '';\n  const hasWebsite = typeof s.has_website === 'boolean' ? (s.has_website ? 'si' : 'no') : '';\n  const coords = Array.isArray(s.location?.coordinates) ? s.location.coordinates : [];\n\n  const text = [\n    `Negocio: ${s.name ?? ''}`,\n    `Categoria: ${category}`,\n    `Barrio: ${barrio}`,\n    `Direccion: ${address}`,\n    `Score: ${score}`,\n    `Gap: ${gap}`,\n    `Resenas: ${reviews}`,\n    `Web: ${hasWebsite}`,\n    `Coordenadas: ${coords.join(',')}`\n  ].filter(Boolean).join('\\n');\n\n  out.push({\n    json: {\n      point_id: id,\n      embedding_input: text,\n      payload: {\n        name: s.name ?? null,\n        category: s.category ?? null,\n        subcategory: s.subcategory ?? null,\n        neighborhood: barrio || null,\n        address: address || null,\n        score: s.score ?? null,\n        gap: s.gap ?? null,\n        reviews: s.reviews ?? null,\n        has_website: s.has_website ?? null,\n        source: 'shops',\n        text\n      }\n    }\n  });\n}\nreturn out;"
      },
