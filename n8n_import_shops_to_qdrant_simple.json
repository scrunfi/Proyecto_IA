    {
      "parameters": {
        "jsCode": "const out = [];\nfor (const item of $input.all()) {\n  const j = item.json || {};\n  const vector = j.embedding || j.data?.[0]?.embedding;\n  if (!Array.isArray(vector) || vector.length === 0) continue;\n\n  out.push({\n    json: {\n      points: [\n        {\n          id: j.point_id,\n          vector,\n          payload: j.payload || {}\n        }\n      ]\n    }\n  });\n}\nreturn out;"
      },
