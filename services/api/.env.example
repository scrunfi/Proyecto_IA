MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=almeria
MONGO_DB_NAME=almeria_shop

OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_SECONDS=60
OVERPASS_USER_AGENT=ProyectoAlmeria/1.0
# Formato: sur,oeste,norte,este (bbox centrado en Almeria ciudad)
OVERPASS_BBOX=36.76,-2.67,36.93,-2.29

BARRIOS_GEOJSON_PATH=app/data/barrios.geojson

# Webhook de n8n para analisis por negocio (POST JSON: {"id": <osm_id>})
N8N_WEBHOOK_URL=
# Webhook de n8n para solicitud de web por negocio (boton "Solicitar web")
# Si se deja vacio, se reutiliza N8N_WEBHOOK_URL
N8N_WEBHOOK_WEB_URL=
# Opcional si tu webhook usa autenticacion
N8N_WEBHOOK_AUTH_HEADER=
N8N_WEBHOOK_AUTH_VALUE=
# Timeout general para webhooks n8n (segundos)
N8N_TIMEOUT_SECONDS=420
# Timeout especifico para el flujo "Solicitar web"
N8N_WEB_TIMEOUT_SECONDS=1800
